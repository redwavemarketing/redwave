// Redwave ERP/HRM — Prisma schema.
//
// Full data model: 48 entities across 12 modules, translated from docs/data-model.md
// (the authoritative data dictionary). The visual ERD is docs/Redwave_Data_Model.drawio.
//
// ───────────────────────────────────────────────────────────────────────────────
// SCHEMA CONVENTIONS (decided & recorded in CLAUDE.md):
//   • Models are PascalCase, mapped to the dictionary's snake_case tables via @@map.
//     Columns stay snake_case (1:1 with the dictionary). Client is idiomatic (prisma.user).
//   • Surrogate PKs: id String @id @default(uuid()) @db.Uuid. Business keys are @unique;
//     join tables use composite @@id. Rep codes never reused (rep_code @unique). — §3 #11
//
// MONEY CONVENTION (CLAUDE.md §3 #1 — exact-decimal money, never floats):
//   • Every monetary column is `Decimal @db.Decimal(12, 2)` (Postgres NUMERIC), surfaced
//     in TypeScript as `Prisma.Decimal`. NEVER `Float` / `number`.
//   • Do arithmetic with Prisma.Decimal methods (.plus/.minus/.times), never JS float math.
//   • Non-money decimals use targeted precision: pct (5,4), *_km (10,2), rate_per_km (6,3),
//     lat/lng (9,6).
//   • Effective-dated config rows carry effective_from / effective_to (CLAUDE.md §3 #10).
//   • sale_items snapshot fields (tier_at_payment, rate_applied, commission_paid,
//     incentive_amount) are written ONCE at payment and immutable thereafter (§3 #2);
//     they are nullable until paid.
//   • The two rate streams (client_billing_rates vs commission_*) never join (§3 #3).
//   • Pay-run finalize (#8) and import commit run inside Prisma INTERACTIVE TRANSACTIONS
//     (`prisma.$transaction(async (tx) => { ... })`) for atomic, idempotent writes.
// ───────────────────────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL") // pooled (PgBouncer) connection — runtime queries
  directUrl = env("DIRECT_URL") // direct connection — migrations & introspection
}

// ════════════════════════════════════════════════════════════════════════════════
// ENUMS (one per dictionary "enum" field)
// ════════════════════════════════════════════════════════════════════════════════

enum ThemePreference {
  light
  dark
  system
}

enum UserStatus {
  active
  inactive
}

enum PermissionAction {
  view
  create
  edit
  approve
  delete
  export
  broadcast // one off-grid action: gates the manual notification broadcast (Super Admin)
  business // off-grid: gates the business/executive dashboard + cross-period trends (Super Admin)
}

enum ProfileChangeStatus {
  pending
  approved
  rejected
}

enum RepStatus {
  active
  terminated
}

enum EquipmentStatus {
  assigned
  returned
  withheld
}

enum Market {
  CA
  US
}

// Commission BEHAVIOUR classification for a product type (read by the engine seam, not the engine
// itself). LOCKED for the 4 core types; new SA types are always standard_addon. — §3 #5/#9, §6
enum ProductTypeBehaviour {
  tiered // counts toward the internet tier tally (internet only) — #5
  greenfield // flat-rated, excluded from the tally (greenfield_internet) — #9
  standard_addon // billable, flat-rated, NOT tiered, NOT greenfield (tv / home_phone / new types)
}

enum RateKind {
  product
  tv_addon
  hp_addon
  bundle_bonus
  spiff
}

enum IncentiveTargetType {
  per_activation
  one_time // a single bonus once the rep reaches target_count matching activations (was target_based)
}

enum IncentiveStatus {
  active
  ended
}

enum SaleStatus {
  entered
  validated
  in_pay_run
  paid
  clawed_back
  deleted
  historical // migrated/already-paid sale — reference-only; never enters the pay pipeline (excluded from
  // commission/tier/leaderboard/holdback/clawback), shown only in business aggregations. Set ONLY at import.
}

enum SaleItemStatus {
  active
  cancelled
  clawed_back
}

enum PayPeriodStatus {
  open
  closed
  paid
}

enum PayRunStatus {
  draft
  finalized
  exported
}

enum HoldbackReleaseStatus {
  held
  scheduled
  released
}

enum ClawbackStatus {
  pending
  applied
}

enum ExpenseReportStatus {
  draft
  submitted
  approved
  rejected
  sent_back
}

enum ExpenseCategory {
  km
  meals
  hotel
  flight
  rental
  gas
  other
}

enum TripType {
  single
  round
}

enum ExportFormat {
  pdf
  excel
}

enum DocumentType {
  compensation_agreement
  rate_notice
  equipment
  other
}

enum DocumentStatus {
  draft
  shared
  partially_signed
  completed
  declined
}

enum SignatureRequestStatus {
  pending
  completed
  declined
  cancelled
}

enum SignatureStatus {
  pending
  signed
  declined
}

enum SignatureFieldType {
  signature
  initial
  date
  text
}

enum SignatureMethod {
  drawn
  typed
  uploaded
}

enum TargetType {
  daily
  weekly
  monthly
}

enum NotificationChannel {
  in_app
  email
}

enum ChatbotRole {
  user
  assistant
}

enum ImportSourceType {
  client_report
  master_migration
  balance_migration
}

enum ImportType {
  reps
  clients
  products
  billing_rates
  sales
  holdback
  clawback
  mixed
}

enum ImportBatchStatus {
  staged
  committed
  failed
  cancelled
}

enum MatchStatus {
  matched
  unmatched
  duplicate
  error
  ignored
}

// ════════════════════════════════════════════════════════════════════════════════
// MODULE 1 — Auth & RBAC
// ════════════════════════════════════════════════════════════════════════════════

model User {
  id                    String          @id @default(uuid()) @db.Uuid
  email                 String          @unique
  password_hash         String
  full_name             String
  phone                 String?
  avatar_url            String?
  theme_preference      ThemePreference
  status                UserStatus
  must_change_password  Boolean         @default(false) // set on invite / admin reset — forces a change at next login
  failed_login_attempts Int             @default(0) // brute-force counter; reset on success
  locked_until          DateTime? // lockout expiry; null = not locked
  created_at            DateTime        @default(now())
  updated_at            DateTime        @updatedAt

  // back-relations (all FKs that reference users.id)
  roles_created                 Role[]                     @relation("RoleCreatedBy")
  user_roles                    UserRole[]
  audit_logs                    AuditLog[]                 @relation("AuditActor")
  profile_changes_subject       ProfileChangeRequest[]     @relation("ProfileSubject")
  profile_changes_requested     ProfileChangeRequest[]     @relation("ProfileRequestedBy")
  profile_changes_reviewed      ProfileChangeRequest[]     @relation("ProfileReviewedBy")
  rep_login                     Rep?                       @relation("RepLogin")
  reps_managed                  Rep[]                      @relation("RepFieldManager")
  billing_rates_created         ClientBillingRate[]        @relation("BillingRateCreatedBy")
  tier_configs_created          CommissionTierConfig[]     @relation("TierConfigCreatedBy")
  flat_rates_created            CommissionFlatRate[]       @relation("FlatRateCreatedBy")
  holdback_release_set          HoldbackReleaseSetting[]   @relation("HoldbackReleaseSetBy")
  incentives_created            Incentive[]                @relation("IncentiveCreatedBy")
  sales_validated               Sale[]                     @relation("SaleValidatedBy")
  pay_runs_executed             PayRun[]                   @relation("PayRunExecutedBy")
  clawbacks_entered             Clawback[]                 @relation("ClawbackEnteredBy")
  expense_reports_submitted     ExpenseReport[]            @relation("ExpenseSubmittedBy")
  expense_reports_approved      ExpenseReport[]            @relation("ExpenseApprovedBy")
  expense_items_submitted       ExpenseItem[]              @relation("ExpenseItemSubmittedBy")
  expense_items_approved        ExpenseItem[]              @relation("ExpenseItemApprovedBy")
  expense_field_configs_created ExpenseFieldConfig[]       @relation("ExpenseFieldConfigCreatedBy")
  expense_exports_generated     ExpenseExport[]            @relation("ExpenseExportGeneratedBy")
  report_exports_generated      ReportExport[]             @relation("ReportExportGeneratedBy")
  statements_generated          ClientStatement[]          @relation("StatementGeneratedBy")
  invoices_generated            ClientInvoice[]            @relation("InvoiceGeneratedBy")
  billing_exports_generated     BillingExport[]            @relation("BillingExportGeneratedBy")
  documents_owned               Document[]                 @relation("DocumentOwner")
  signature_requests_sent       SignatureRequest[]         @relation("SignatureRequestedBy")
  document_signatures           DocumentSignature[]        @relation("SignatureRecipient")
  signature_fields_assigned     SignatureField[]           @relation("SignatureFieldRecipient")
  user_signatures               UserSignature[]            @relation("UserSignatureOwner")
  notif_settings_updated        NotificationEventSetting[] @relation("NotifSettingUpdatedBy")
  notifications                 Notification[]
  chatbot_conversations         ChatbotConversation[]
  chatbot_configs_updated       ChatbotConfig[]            @relation("ChatbotConfigUpdatedBy")
  sales_targets_set             SalesTarget[]              @relation("SalesTargetSetBy")
  import_batches_run            ImportBatch[]              @relation("ImportBatchRunBy")
  import_mappings_created       ImportFieldMapping[]       @relation("ImportMappingCreatedBy")
  import_rows_resolved          ImportRow[]                @relation("ImportRowResolvedBy")
  password_reset_tokens         PasswordResetToken[]
  refresh_sessions              RefreshSession[]           @relation("RefreshSessionUser")
  user_mfa                      UserMfa?                   @relation("UserMfaOwner")
  mfa_recovery_codes            MfaRecoveryCode[]          @relation("MfaRecoveryOwner")
  security_settings_updated     SecuritySetting[]          @relation("SecuritySettingUpdatedBy")

  @@map("users")
}

// A persisted refresh-token session (one per device/login). The current refresh token is stored only as a
// HASH; each /auth/refresh ROTATES it (new hash on the SAME row). A presented token that ≠ the stored hash
// is a REUSE → the session is revoked (breach detection). Access + refresh tokens carry this row's id as
// `sid`; the JwtAuthGuard rejects any token whose session is revoked → immediate force-logout. — arch §security
model RefreshSession {
  id           String    @id @default(uuid()) @db.Uuid
  user_id      String    @db.Uuid
  user         User      @relation("RefreshSessionUser", fields: [user_id], references: [id])
  token_hash   String    @unique
  user_agent   String?
  ip_address   String?
  created_at   DateTime  @default(now())
  last_used_at DateTime  @default(now())
  expires_at   DateTime
  revoked_at   DateTime?

  @@index([user_id])
  @@map("refresh_sessions")
}

// Per-user TOTP MFA. `secret` is the base32 TOTP secret; `enabled` flips true only after a successful verify
// during enrollment (an unconfirmed row exists between setup and enable). — AUTH MFA
model UserMfa {
  user_id      String    @id @db.Uuid
  user         User      @relation("UserMfaOwner", fields: [user_id], references: [id])
  secret       String
  enabled      Boolean   @default(false)
  confirmed_at DateTime?
  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt

  @@map("user_mfa")
}

// One-time MFA recovery code (hashed). Used to sign in if the authenticator app is lost. — AUTH MFA
model MfaRecoveryCode {
  id         String    @id @default(uuid()) @db.Uuid
  user_id    String    @db.Uuid
  user       User      @relation("MfaRecoveryOwner", fields: [user_id], references: [id])
  code_hash  String
  used_at    DateTime?
  created_at DateTime  @default(now())

  @@index([user_id])
  @@map("mfa_recovery_codes")
}

// Singleton security-policy row. `mfa_enforced` gates whether `roles.mfa_required` actually BLOCKS login —
// default false so per-user MFA can be enabled without locking testers out mid-cycle. — AUTH MFA
model SecuritySetting {
  id           String   @id @default(uuid()) @db.Uuid
  mfa_enforced Boolean  @default(false)
  updated_by   String?  @db.Uuid
  updater      User?    @relation("SecuritySettingUpdatedBy", fields: [updated_by], references: [id])
  updated_at   DateTime @default(now()) @updatedAt

  @@map("security_settings")
}

enum PasswordTokenPurpose {
  invite
  reset
}

// A single-use, expiring token for an invite (first set-password) or a forgotten-password reset. Only the
// token HASH is stored (the plaintext lives only in the emailed link). — AUTH-002
model PasswordResetToken {
  id         String               @id @default(uuid()) @db.Uuid
  user_id    String               @db.Uuid
  user       User                 @relation(fields: [user_id], references: [id])
  token_hash String               @unique
  purpose    PasswordTokenPurpose
  expires_at DateTime
  used_at    DateTime?
  created_at DateTime             @default(now())

  @@index([user_id])
  @@map("password_reset_tokens")
}

model Role {
  id           String   @id @default(uuid()) @db.Uuid
  name         String   @unique
  description  String?
  is_system    Boolean
  mfa_required Boolean  @default(false) // policy: members must use MFA when enforcement is on (SA seeded true). — AUTH MFA
  created_by   String   @db.Uuid
  creator      User     @relation("RoleCreatedBy", fields: [created_by], references: [id])
  created_at   DateTime @default(now())

  role_permissions RolePermission[]
  user_roles       UserRole[]

  @@map("roles")
}

model Module {
  id          String  @id @default(uuid()) @db.Uuid
  key         String  @unique
  name        String
  description String?

  permissions Permission[]

  @@map("modules")
}

model Permission {
  id          String           @id @default(uuid()) @db.Uuid
  module_id   String           @db.Uuid
  module      Module           @relation(fields: [module_id], references: [id])
  action      PermissionAction
  description String?

  role_permissions RolePermission[]

  // A permission is a single (module, action) capability — docs/data-model.md §3.
  // Uniqueness enables idempotent seeding and safe grant assignment.
  @@unique([module_id, action])
  @@map("permissions")
}

model RolePermission {
  role_id       String     @db.Uuid
  role          Role       @relation(fields: [role_id], references: [id])
  permission_id String     @db.Uuid
  permission    Permission @relation(fields: [permission_id], references: [id])

  @@id([role_id, permission_id])
  @@map("role_permissions")
}

model UserRole {
  user_id String @db.Uuid
  user    User   @relation(fields: [user_id], references: [id])
  role_id String @db.Uuid
  role    Role   @relation(fields: [role_id], references: [id])

  @@id([user_id, role_id])
  @@map("user_roles")
}

model AuditLog {
  id          String   @id @default(uuid()) @db.Uuid
  user_id     String   @db.Uuid
  actor       User     @relation("AuditActor", fields: [user_id], references: [id])
  entity_type String
  entity_id   String   @db.Uuid // polymorphic — no relation
  action      String
  before_json Json?
  after_json  Json?
  ip_address  String? // actor's request IP, captured from the request context. — arch §security (audit)
  created_at  DateTime @default(now())

  @@index([entity_type, entity_id])
  @@map("audit_log")
}

model ProfileChangeRequest {
  id               String              @id @default(uuid()) @db.Uuid
  user_id          String              @db.Uuid
  subject          User                @relation("ProfileSubject", fields: [user_id], references: [id])
  requested_by     String              @db.Uuid
  requester        User                @relation("ProfileRequestedBy", fields: [requested_by], references: [id])
  proposed_changes Json
  status           ProfileChangeStatus
  reviewed_by      String?             @db.Uuid
  reviewer         User?               @relation("ProfileReviewedBy", fields: [reviewed_by], references: [id])
  reviewed_at      DateTime?
  created_at       DateTime            @default(now())

  @@map("profile_change_requests")
}

// ════════════════════════════════════════════════════════════════════════════════
// MODULE 2 — HRM / Reps
// ════════════════════════════════════════════════════════════════════════════════

model Rep {
  id               String    @id @default(uuid()) @db.Uuid
  rep_code         String    @unique
  user_id          String?   @unique @db.Uuid
  login            User?     @relation("RepLogin", fields: [user_id], references: [id])
  full_name        String
  field_manager_id String    @db.Uuid
  field_manager    User      @relation("RepFieldManager", fields: [field_manager_id], references: [id])
  status           RepStatus
  hire_date        DateTime  @db.Date
  termination_date DateTime? @db.Date
  payment_details  Json?
  created_at       DateTime  @default(now())

  rep_documents   RepDocument[]
  rep_equipment   RepEquipment[]
  sales           Sale[]
  pay_run_lines   PayRunLine[]
  holdback_ledger HoldbackLedger[]
  clawbacks       Clawback[]
  expense_reports ExpenseReport[]
  expense_items   ExpenseItem[]
  sales_targets   SalesTarget[]

  @@map("reps")
}

model RepDocument {
  id          String   @id @default(uuid()) @db.Uuid
  rep_id      String   @db.Uuid
  rep         Rep      @relation(fields: [rep_id], references: [id])
  doc_type    String
  file_url    String
  uploaded_at DateTime @default(now())

  @@map("rep_documents")
}

model RepEquipment {
  id             String          @id @default(uuid()) @db.Uuid
  rep_id         String          @db.Uuid
  rep            Rep             @relation(fields: [rep_id], references: [id])
  equipment_type String
  identifier     String
  deposit_amount Decimal         @db.Decimal(12, 2)
  assigned_date  DateTime        @db.Date
  returned_date  DateTime?       @db.Date
  status         EquipmentStatus

  @@map("rep_equipment")
}

// ════════════════════════════════════════════════════════════════════════════════
// MODULE 3 — Clients & Products
// ════════════════════════════════════════════════════════════════════════════════

model Client {
  id              String   @id @default(uuid()) @db.Uuid
  client_code     String   @unique
  name            String
  market          Market
  supplies_mpu_id Boolean
  is_active       Boolean
  created_at      DateTime @default(now())

  products              Product[]
  client_billing_rates  ClientBillingRate[]
  custom_fields         ClientCustomField[]
  incentives            Incentive[]
  sales                 Sale[]
  expense_items         ExpenseItem[]
  expense_exports       ExpenseExport[]
  client_statements     ClientStatement[]
  client_invoices       ClientInvoice[]
  import_batches        ImportBatch[]
  import_field_mappings ImportFieldMapping[]

  @@index([is_active]) // list filter (active/inactive)
  @@map("clients")
}

// CLIENT CUSTOM FIELD — SA-defined name/value pairs carrying extra info beyond the fixed client columns.
// Replace-in-place on client create/edit (no cascade). — SRS CLNT (custom fields)
model ClientCustomField {
  id            String   @id @default(uuid()) @db.Uuid
  client_id     String   @db.Uuid
  client        Client   @relation(fields: [client_id], references: [id])
  field_name    String
  field_value   String
  display_order Int
  created_at    DateTime @default(now())

  @@index([client_id])
  @@map("client_custom_fields")
}

// PRODUCT-TYPE CATALOGUE — the configurable set of product types + their LOCKED commission
// behaviour. internet=tiered (#5), greenfield_internet=greenfield (#9, flat $100 excluded from the
// tally), tv/home_phone=standard_addon. New SA types are forced standard_addon and can NEVER change
// tally/greenfield logic. The 4 core types are is_system (behaviour immutable, non-deletable). The
// `key` is the natural PK that product_type columns reference. — §6
model ProductTypeCatalogue {
  key        String               @id
  label      String
  behaviour  ProductTypeBehaviour
  is_system  Boolean
  is_active  Boolean
  created_at DateTime             @default(now())

  products   Product[]
  flat_rates CommissionFlatRate[]
  incentives Incentive[]

  @@map("product_type_catalogue")
}

model Product {
  id                String               @id @default(uuid()) @db.Uuid
  client_id         String               @db.Uuid
  client            Client               @relation(fields: [client_id], references: [id])
  name              String
  product_type      String // FK → product_type_catalogue.key
  product_type_ref  ProductTypeCatalogue @relation(fields: [product_type], references: [key])
  is_active         Boolean
  created_at        DateTime             @default(now())

  client_billing_rates ClientBillingRate[]
  sale_items           SaleItem[]

  @@index([client_id, is_active]) // nested per-client product list
  @@index([product_type]) // cross-client product list filter
  @@map("products")
}

// CLIENT BILLING RATE — what Redwave charges the CLIENT. Separate stream from
// commission_* and never joined with it. — CLAUDE.md §3 #3
model ClientBillingRate {
  id             String    @id @default(uuid()) @db.Uuid
  client_id      String    @db.Uuid
  client         Client    @relation(fields: [client_id], references: [id])
  product_id     String?   @db.Uuid
  product        Product?  @relation(fields: [product_id], references: [id])
  rate_kind      RateKind
  amount         Decimal   @db.Decimal(12, 2)
  effective_from DateTime  @db.Date
  effective_to   DateTime? @db.Date
  created_by     String    @db.Uuid
  creator        User      @relation("BillingRateCreatedBy", fields: [created_by], references: [id])

  @@map("client_billing_rates")
}

// ════════════════════════════════════════════════════════════════════════════════
// MODULE 4 — Commission Config (REP commission stream; separate from billing rates)
// ════════════════════════════════════════════════════════════════════════════════

model CommissionTierConfig {
  id             String    @id @default(uuid()) @db.Uuid
  effective_from DateTime  @db.Date
  effective_to   DateTime? @db.Date
  created_by     String    @db.Uuid
  creator        User      @relation("TierConfigCreatedBy", fields: [created_by], references: [id])

  tiers CommissionTier[]

  @@map("commission_tier_configs")
}

model CommissionTier {
  id                  String               @id @default(uuid()) @db.Uuid
  tier_config_id      String               @db.Uuid
  tier_config         CommissionTierConfig @relation(fields: [tier_config_id], references: [id])
  tier_number         Int
  min_count           Int
  max_count           Int? // null for the open 36+ bracket
  rate_per_activation Decimal              @db.Decimal(12, 2)

  @@map("commission_tiers")
}

model CommissionFlatRate {
  id               String               @id @default(uuid()) @db.Uuid
  product_type     String // FK → product_type_catalogue.key
  product_type_ref ProductTypeCatalogue @relation(fields: [product_type], references: [key])
  amount           Decimal              @db.Decimal(12, 2)
  effective_from   DateTime             @db.Date
  effective_to     DateTime?            @db.Date
  created_by       String               @db.Uuid
  creator          User                 @relation("FlatRateCreatedBy", fields: [created_by], references: [id])

  @@map("commission_flat_rates")
}

model HoldbackConfig {
  id             String    @id @default(uuid()) @db.Uuid
  advance_pct    Decimal   @db.Decimal(5, 4)
  holdback_pct   Decimal   @db.Decimal(5, 4)
  effective_from DateTime  @db.Date
  effective_to   DateTime? @db.Date

  @@map("holdback_config")
}

model HoldbackReleaseSetting {
  id             String   @id @default(uuid()) @db.Uuid
  release_rule   String
  set_by         String   @db.Uuid
  setter         User     @relation("HoldbackReleaseSetBy", fields: [set_by], references: [id])
  effective_from DateTime // timestamp; sticky until changed

  @@map("holdback_release_settings")
}

model Incentive {
  id                 String              @id @default(uuid()) @db.Uuid
  name                   String
  scope_client_id        String?               @db.Uuid
  scope_client           Client?               @relation(fields: [scope_client_id], references: [id])
  scope_product_type     String? // FK → product_type_catalogue.key (null = all types)
  scope_product_type_ref ProductTypeCatalogue? @relation(fields: [scope_product_type], references: [key])
  target_type            IncentiveTargetType
  target_count       Int?
  window_start       DateTime            @db.Date
  window_end         DateTime            @db.Date
  amount             Decimal             @db.Decimal(12, 2)
  status             IncentiveStatus
  created_by         String              @db.Uuid
  creator            User                @relation("IncentiveCreatedBy", fields: [created_by], references: [id])

  sale_items SaleItem[]

  @@map("incentives")
}

// ════════════════════════════════════════════════════════════════════════════════
// MODULE 5 — Sales & Validation
// ════════════════════════════════════════════════════════════════════════════════

model Sale {
  id              String     @id @default(uuid()) @db.Uuid
  sale_code       String     @unique
  sale_date       DateTime   @db.Date // KING — governs the pay period. — §3 #7
  activation_date DateTime?  @db.Date // reference only; drives no logic
  rep_id          String     @db.Uuid
  rep             Rep        @relation(fields: [rep_id], references: [id])
  client_id       String     @db.Uuid
  client          Client     @relation(fields: [client_id], references: [id])
  customer_name   String
  street          String
  city            String
  province_state  String
  postal_code     String
  mpu_id          String?
  is_greenfield   Boolean
  status          SaleStatus
  validated_by    String?    @db.Uuid
  validator       User?      @relation("SaleValidatedBy", fields: [validated_by], references: [id])
  validated_at    DateTime?
  pay_run_id      String?    @db.Uuid
  pay_run         PayRun?    @relation(fields: [pay_run_id], references: [id])
  import_batch_id String?    @db.Uuid // provenance for imported sales (bulk-validated / historical); no FK (polymorphic, IMP-008)
  created_at      DateTime   @default(now())

  sale_items             SaleItem[]
  clawbacks              Clawback[]
  client_statement_lines ClientStatementLine[]

  @@index([rep_id, sale_date])
  @@index([client_id, mpu_id])
  @@index([status]) // list filter by status (validation queue, etc.)
  @@index([client_id, sale_date]) // billing/statement scans by client + date
  @@index([import_batch_id]) // trace imported sales back to their batch
  @@map("sales")
}

// SALE ITEM — carries the IMMUTABLE pay snapshot. tier_at_payment / rate_applied /
// commission_paid / incentive_amount are frozen at payment and never updated. — §3 #2
model SaleItem {
  id                  String         @id @default(uuid()) @db.Uuid
  sale_id             String         @db.Uuid
  sale                Sale           @relation(fields: [sale_id], references: [id])
  product_id          String         @db.Uuid
  product             Product        @relation(fields: [product_id], references: [id])
  product_type        String // frozen snapshot (no FK — #2 immutable)
  counts_toward_tally Boolean
  tier_at_payment     Int? // SNAPSHOT (internet only; null until paid)
  rate_applied        Decimal?       @db.Decimal(12, 2) // SNAPSHOT
  commission_paid     Decimal?       @db.Decimal(12, 2) // SNAPSHOT
  incentive_id        String?        @db.Uuid
  incentive           Incentive?     @relation(fields: [incentive_id], references: [id])
  incentive_amount    Decimal?       @db.Decimal(12, 2) // SNAPSHOT
  historical_billed_amount Decimal?  @db.Decimal(12, 2) // historical sales only — the source-file BILLED amount
  // (a billing-stream reference for business aggregations; NOT commission, never joined to commission_*, #3)
  item_status         SaleItemStatus

  clawbacks Clawback[]

  @@map("sale_items")
}

// ════════════════════════════════════════════════════════════════════════════════
// MODULE 6 — Pay Run & Holdback
// ════════════════════════════════════════════════════════════════════════════════

model PayPeriod {
  id            String          @id @default(uuid()) @db.Uuid
  period_number Int             @unique
  start_date    DateTime        @db.Date
  end_date      DateTime        @db.Date
  payday        DateTime        @db.Date
  status        PayPeriodStatus

  pay_runs           PayRun[]
  holdback_origin    HoldbackLedger[]  @relation("HoldbackOrigin")
  holdback_scheduled HoldbackLedger[]  @relation("HoldbackScheduledRelease")
  expense_reports    ExpenseReport[]
  expense_items      ExpenseItem[]
  expense_exports    ExpenseExport[]
  client_statements  ClientStatement[]
  client_invoices    ClientInvoice[]

  @@map("pay_periods")
}

model PayRun {
  id            String       @id @default(uuid()) @db.Uuid
  pay_period_id String       @db.Uuid
  pay_period    PayPeriod    @relation(fields: [pay_period_id], references: [id])
  run_date      DateTime     @db.Date
  status        PayRunStatus
  executed_by   String       @db.Uuid
  executor      User         @relation("PayRunExecutedBy", fields: [executed_by], references: [id])
  created_at    DateTime     @default(now())

  pay_run_lines     PayRunLine[]
  sales             Sale[]
  holdback_released HoldbackLedger[] @relation("HoldbackReleasedIn")
  clawbacks         Clawback[]

  @@map("pay_runs")
}

model PayRunLine {
  id                  String  @id @default(uuid()) @db.Uuid
  pay_run_id          String  @db.Uuid
  pay_run             PayRun  @relation(fields: [pay_run_id], references: [id])
  rep_id              String  @db.Uuid
  rep                 Rep     @relation(fields: [rep_id], references: [id])
  commission_70       Decimal @db.Decimal(12, 2)
  holdback_release_30 Decimal @db.Decimal(12, 2)
  expense_total       Decimal @db.Decimal(12, 2)
  incentive_total     Decimal @db.Decimal(12, 2)
  bonus_amount        Decimal @db.Decimal(12, 2)
  bonus_note          String?
  clawback_total      Decimal @db.Decimal(12, 2)
  net_payout          Decimal @db.Decimal(12, 2)

  @@map("pay_run_lines")
}

model HoldbackLedger {
  id                          String                @id @default(uuid()) @db.Uuid
  rep_id                      String                @db.Uuid
  rep                         Rep                   @relation(fields: [rep_id], references: [id])
  origin_pay_period_id        String                @db.Uuid
  origin_pay_period           PayPeriod             @relation("HoldbackOrigin", fields: [origin_pay_period_id], references: [id])
  amount_held                 Decimal               @db.Decimal(12, 2)
  scheduled_release_period_id String?               @db.Uuid
  scheduled_release_period    PayPeriod?            @relation("HoldbackScheduledRelease", fields: [scheduled_release_period_id], references: [id])
  release_status              HoldbackReleaseStatus
  released_in_pay_run_id      String?               @db.Uuid
  released_in_pay_run         PayRun?               @relation("HoldbackReleasedIn", fields: [released_in_pay_run_id], references: [id])
  amount_released             Decimal?              @db.Decimal(12, 2)
  clawback_applied            Decimal?              @db.Decimal(12, 2)

  @@index([rep_id, release_status])
  @@map("holdback_ledger")
}

// ════════════════════════════════════════════════════════════════════════════════
// MODULE 7 — Clawback (flat deduction; exact amount from the snapshot). — §3 #4, #6
// ════════════════════════════════════════════════════════════════════════════════

model Clawback {
  id                    String         @id @default(uuid()) @db.Uuid
  sale_item_id          String         @db.Uuid
  sale_item             SaleItem       @relation(fields: [sale_item_id], references: [id])
  sale_id               String         @db.Uuid
  sale                  Sale           @relation(fields: [sale_id], references: [id])
  rep_id                String         @db.Uuid
  rep                   Rep            @relation(fields: [rep_id], references: [id])
  amount                Decimal        @db.Decimal(12, 2)
  reason                String
  reported_date         DateTime       @db.Date
  entered_by            String         @db.Uuid
  enterer               User           @relation("ClawbackEnteredBy", fields: [entered_by], references: [id])
  applied_in_pay_run_id String?        @db.Uuid
  applied_in_pay_run    PayRun?        @relation(fields: [applied_in_pay_run_id], references: [id])
  status                ClawbackStatus
  created_at            DateTime       @default(now())

  @@map("clawbacks")
}

// ════════════════════════════════════════════════════════════════════════════════
// MODULE 8 — Expenses
// ════════════════════════════════════════════════════════════════════════════════

model ExpenseReport {
  id            String              @id @default(uuid()) @db.Uuid
  submitted_by  String              @db.Uuid
  submitter     User                @relation("ExpenseSubmittedBy", fields: [submitted_by], references: [id])
  rep_id        String?             @db.Uuid
  rep           Rep?                @relation(fields: [rep_id], references: [id])
  week_start    DateTime            @db.Date
  week_end      DateTime            @db.Date
  status        ExpenseReportStatus
  approved_by   String?             @db.Uuid
  approver      User?               @relation("ExpenseApprovedBy", fields: [approved_by], references: [id])
  approved_at   DateTime?
  pay_period_id String?             @db.Uuid
  pay_period    PayPeriod?          @relation(fields: [pay_period_id], references: [id])
  created_at    DateTime            @default(now())

  expense_items ExpenseItem[]

  @@map("expense_reports")
}

// ITEM-FIRST (Config batch): the expense ITEM is the atomic unit. It carries its own submitter,
// status, approver, and a pay_period DERIVED from its expense_date (same-cycle payout, EXP-009).
// expense_report_id is NULLABLE — new items are created report-less; the report wrapper is kept
// only as optional internal grouping/history. — SRS §11 / BRD §7
model ExpenseItem {
  id                String              @id @default(uuid()) @db.Uuid
  expense_report_id String?             @db.Uuid
  expense_report    ExpenseReport?      @relation(fields: [expense_report_id], references: [id])
  rep_id            String?             @db.Uuid
  rep               Rep?                @relation(fields: [rep_id], references: [id])
  submitted_by      String              @db.Uuid
  submitter         User                @relation("ExpenseItemSubmittedBy", fields: [submitted_by], references: [id])
  category          ExpenseCategory
  client_id         String?             @db.Uuid
  client            Client?             @relation(fields: [client_id], references: [id])
  expense_date      DateTime            @db.Date
  amount            Decimal             @db.Decimal(12, 2)
  description       String
  receipt_url       String? // mandatory except km
  status            ExpenseReportStatus
  approved_by       String?             @db.Uuid
  approver          User?               @relation("ExpenseItemApprovedBy", fields: [approved_by], references: [id])
  approved_at       DateTime?
  pay_period_id     String?             @db.Uuid // derived from expense_date (governs payout cycle, EXP-009)
  pay_period        PayPeriod?          @relation(fields: [pay_period_id], references: [id])
  created_at        DateTime            @default(now())

  km_log ExpenseKmLog?

  @@index([rep_id, pay_period_id, status]) // the Pay Run aggregation query
  @@index([submitted_by]) // own-scope list
  @@index([status]) // approval queue / pending count
  @@index([expense_date]) // date-range filter + daily/weekly/monthly grouping
  @@map("expense_items")
}

model ExpenseKmLog {
  id              String      @id @default(uuid()) @db.Uuid
  expense_item_id String      @unique @db.Uuid
  expense_item    ExpenseItem @relation(fields: [expense_item_id], references: [id])
  trip_type       TripType
  total_km        Decimal     @db.Decimal(10, 2)
  deduction_km    Decimal     @db.Decimal(10, 2)
  billable_km     Decimal     @db.Decimal(10, 2)
  rate_per_km     Decimal     @db.Decimal(6, 3)
  computed_amount Decimal     @db.Decimal(12, 2)

  stops ExpenseKmStop[]

  @@map("expense_km_logs")
}

model ExpenseKmStop {
  id         String       @id @default(uuid()) @db.Uuid
  km_log_id  String       @db.Uuid
  km_log     ExpenseKmLog @relation(fields: [km_log_id], references: [id])
  stop_order Int
  address    String
  lat        Decimal      @db.Decimal(9, 6)
  lng        Decimal      @db.Decimal(9, 6)

  @@map("expense_km_stops")
}

model ExpenseFieldConfig {
  id               String  @id @default(uuid()) @db.Uuid
  category_key     String  @unique
  label            String
  requires_receipt Boolean
  is_active        Boolean
  created_by       String  @db.Uuid
  creator          User    @relation("ExpenseFieldConfigCreatedBy", fields: [created_by], references: [id])

  @@map("expense_field_configs")
}

model ExpenseExport {
  id            String       @id @default(uuid()) @db.Uuid
  generated_by  String       @db.Uuid
  generator     User         @relation("ExpenseExportGeneratedBy", fields: [generated_by], references: [id])
  client_id     String?      @db.Uuid
  client        Client?      @relation(fields: [client_id], references: [id])
  pay_period_id String?      @db.Uuid
  pay_period    PayPeriod?   @relation(fields: [pay_period_id], references: [id])
  scope_filters Json
  format        ExportFormat
  file_url      String
  generated_at  DateTime     @default(now())

  @@map("expense_exports")
}

// On-demand REPORT exports (/reports/exports) — the audit record of each client-generated report file
// (who, what, when — mirrors expense_exports). `report_type`/`format` are validated Strings, not enums,
// so adding a report type/format needs no enum migration (the §12 expense-category lesson). The file is
// generated CLIENT-side (lib/export); `filename` records what was downloaded — no stub URL. — SRS RPT-015
model ReportExport {
  id            String   @id @default(uuid()) @db.Uuid
  generated_by  String   @db.Uuid
  generator     User     @relation("ReportExportGeneratedBy", fields: [generated_by], references: [id])
  /// business_summary | leaderboard | payrun_summary | expense_summary (DTO allowlist).
  report_type   String
  /// csv | excel | pdf (DTO allowlist).
  format        String
  /// The scope the caller exported: pay_period_id / from / to + the recorded rep_scope (null = all).
  scope_filters Json
  filename      String
  generated_at  DateTime @default(now())

  @@index([generated_by])
  @@map("report_exports")
}

// ════════════════════════════════════════════════════════════════════════════════
// MODULE 9 — Billing & Statements
// ════════════════════════════════════════════════════════════════════════════════

// Issued billing documents are IMMUTABLE + gapless-numbered. A re-generation creates a NEW numbered
// `issued` version and marks the prior one `superseded` (metadata only — number/total/lines are frozen).
// — BRD §8, arch §6.9
enum BillingDocStatus {
  issued
  superseded
}

model ClientStatement {
  id               String           @id @default(uuid()) @db.Uuid
  statement_number Int?             @unique // gapless, global per type; minted on issue (null only on legacy rows)
  status           BillingDocStatus @default(issued)
  client_id        String           @db.Uuid
  client           Client           @relation(fields: [client_id], references: [id])
  pay_period_id    String           @db.Uuid
  pay_period       PayPeriod        @relation(fields: [pay_period_id], references: [id])
  total_amount     Decimal          @db.Decimal(12, 2)
  file_url         String? // optional — the Excel artifact is rendered on demand (download) / recorded in billing_exports
  generated_by     String           @db.Uuid
  generator        User             @relation("StatementGeneratedBy", fields: [generated_by], references: [id])
  generated_at     DateTime         @default(now())
  superseded_by_id String?          @db.Uuid
  superseded_by    ClientStatement? @relation("StatementSupersede", fields: [superseded_by_id], references: [id])

  lines       ClientStatementLine[]
  supersedes  ClientStatement[]     @relation("StatementSupersede")
  exports     BillingExport[]

  @@index([client_id, pay_period_id, status])
  @@map("client_statements")
}

model ClientStatementLine {
  id               String          @id @default(uuid()) @db.Uuid
  statement_id     String          @db.Uuid
  statement        ClientStatement @relation(fields: [statement_id], references: [id])
  sale_id          String          @db.Uuid
  sale             Sale            @relation(fields: [sale_id], references: [id])
  customer_name    String
  products_summary String
  line_total       Decimal         @db.Decimal(12, 2)

  @@map("client_statement_lines")
}

model ClientInvoice {
  id               String           @id @default(uuid()) @db.Uuid
  invoice_number   Int?             @unique // gapless, global per type; minted on issue (null only on legacy rows)
  status           BillingDocStatus @default(issued)
  client_id        String           @db.Uuid
  client           Client           @relation(fields: [client_id], references: [id])
  pay_period_id    String           @db.Uuid
  pay_period       PayPeriod        @relation(fields: [pay_period_id], references: [id])
  total_commission Decimal          @db.Decimal(12, 2)
  file_url         String? // optional — the PDF is rendered on demand / recorded in billing_exports
  generated_by     String?          @db.Uuid
  generator        User?            @relation("InvoiceGeneratedBy", fields: [generated_by], references: [id])
  generated_at     DateTime         @default(now())
  superseded_by_id String?          @db.Uuid
  superseded_by    ClientInvoice?   @relation("InvoiceSupersede", fields: [superseded_by_id], references: [id])

  supersedes ClientInvoice[] @relation("InvoiceSupersede")
  exports    BillingExport[]

  @@index([client_id, pay_period_id, status])
  @@map("client_invoices")
}

// A monotonic counter per document type ('statement' | 'invoice'). Incremented atomically INSIDE the issue
// transaction (row lock) so numbers are gapless under concurrency. — BRD §8 (gapless numbering)
model DocumentSequence {
  key           String @id // 'statement' | 'invoice'
  current_value Int    @default(0) // highest number issued so far; next() atomically +1 and returns the new value

  @@map("document_sequences")
}

// A recorded export artifact (Excel / PDF / QuickBooks CSV / financial summary), stored in object storage by
// path — like expense_exports. The download endpoints render on demand; configured storage also persists +
// records here. — arch §6.9
model BillingExport {
  id            String           @id @default(uuid()) @db.Uuid
  kind          String // statement | invoice | summary | quickbooks
  format        String // excel | pdf | csv
  statement_id  String?          @db.Uuid
  statement     ClientStatement? @relation(fields: [statement_id], references: [id])
  invoice_id    String?          @db.Uuid
  invoice       ClientInvoice?   @relation(fields: [invoice_id], references: [id])
  client_id     String?          @db.Uuid
  pay_period_id String?          @db.Uuid
  file_path     String
  generated_by  String           @db.Uuid
  generator     User             @relation("BillingExportGeneratedBy", fields: [generated_by], references: [id])
  generated_at  DateTime         @default(now())

  @@index([statement_id])
  @@index([invoice_id])
  @@map("billing_exports")
}

// ════════════════════════════════════════════════════════════════════════════════
// MODULE 10 — Documents & E-Signature
// ════════════════════════════════════════════════════════════════════════════════

model Document {
  id                String         @id @default(uuid()) @db.Uuid
  title             String
  doc_type          DocumentType
  owner_user_id     String         @db.Uuid
  owner             User           @relation("DocumentOwner", fields: [owner_user_id], references: [id])
  original_file_url String
  status            DocumentStatus
  created_at        DateTime       @default(now())

  signature_requests SignatureRequest[]

  @@map("documents")
}

model SignatureRequest {
  id                  String                 @id @default(uuid()) @db.Uuid
  document_id         String                 @db.Uuid
  document            Document               @relation(fields: [document_id], references: [id])
  requested_by        String                 @db.Uuid
  requester           User                   @relation("SignatureRequestedBy", fields: [requested_by], references: [id])
  message             String?
  due_date            DateTime?              @db.Date
  status              SignatureRequestStatus
  completed_file_path String? // the final all-signatures copy (stamped when the request completes, DOC-005)
  created_at          DateTime               @default(now())

  document_signatures DocumentSignature[]
  signature_fields    SignatureField[]

  @@map("signature_requests")
}

model DocumentSignature {
  id                   String           @id @default(uuid()) @db.Uuid
  signature_request_id String           @db.Uuid
  signature_request    SignatureRequest @relation(fields: [signature_request_id], references: [id])
  recipient_user_id    String           @db.Uuid
  recipient            User             @relation("SignatureRecipient", fields: [recipient_user_id], references: [id])
  status               SignatureStatus
  signed_file_url      String? // the per-signer signed copy (object path); the original is never mutated (DOC-004)
  signed_at            DateTime?
  method               String?
  ip_address           String?

  @@map("document_signatures")
}

// A signature FIELD the requester places on the PDF for a specific recipient (where/what to sign).
// Coordinates are normalized fractions 0..1 of the page (TOP-LEFT origin, to match pdf.js/CSS); the
// server converts to pdf-lib points at stamp time. value_* are filled at signing. — SRS DOC-003
model SignatureField {
  id                   String             @id @default(uuid()) @db.Uuid
  signature_request_id String             @db.Uuid
  signature_request    SignatureRequest   @relation(fields: [signature_request_id], references: [id])
  recipient_user_id    String             @db.Uuid
  recipient            User               @relation("SignatureFieldRecipient", fields: [recipient_user_id], references: [id])
  type                 SignatureFieldType
  page                 Int // 0-based page index
  x                    Decimal            @db.Decimal(6, 5) // left, fraction of page width
  y                    Decimal            @db.Decimal(6, 5) // top, fraction of page height
  w                    Decimal            @db.Decimal(6, 5) // width fraction
  h                    Decimal            @db.Decimal(6, 5) // height fraction
  value_text           String? // filled for text/date fields at signing
  value_image_path     String? // filled for signature/initial fields (the applied signature image path)
  created_at           DateTime           @default(now())

  @@index([signature_request_id])
  @@map("signature_fields")
}

// A user's saved, reusable signature (private + own-scoped). Image stored in object storage; one default.
// — SRS DOC (saved signature)
model UserSignature {
  id         String          @id @default(uuid()) @db.Uuid
  user_id    String          @db.Uuid
  user       User            @relation("UserSignatureOwner", fields: [user_id], references: [id])
  label      String
  file_path  String // private object path; served via a short-TTL signed URL, own-scoped
  method     SignatureMethod
  is_default Boolean
  created_at DateTime        @default(now())

  @@index([user_id])
  @@map("user_signatures")
}

// ════════════════════════════════════════════════════════════════════════════════
// MODULE 11 — Reporting & Platform
// ════════════════════════════════════════════════════════════════════════════════

model SalesTarget {
  id           String     @id @default(uuid()) @db.Uuid
  rep_id       String?    @db.Uuid
  rep          Rep?       @relation(fields: [rep_id], references: [id])
  target_type  TargetType
  target_count Int
  period_start DateTime   @db.Date
  period_end   DateTime   @db.Date
  set_by       String     @db.Uuid
  setter       User       @relation("SalesTargetSetBy", fields: [set_by], references: [id])

  @@map("sales_targets")
}

model Notification {
  id                  String              @id @default(uuid()) @db.Uuid
  user_id             String              @db.Uuid
  user                User                @relation(fields: [user_id], references: [id])
  type                String
  channel             NotificationChannel
  title               String
  body                String
  related_entity_type String?
  related_entity_id   String?             @db.Uuid // polymorphic — no relation
  is_read             Boolean
  sent_at             DateTime?
  created_at          DateTime            @default(now())

  @@map("notifications")
}

model NotificationEventSetting {
  id             String   @id @default(uuid()) @db.Uuid
  event_type     String   @unique
  in_app_enabled Boolean
  email_enabled  Boolean
  // Super-Admin-editable presentation: a display label + title/body templates with {var} placeholders the
  // emitter substitutes at send time (null → the call-site title/body is used). — RPT-009 / SRS §14
  label          String?  @db.VarChar(120)
  title_template String?  @db.VarChar(200)
  body_template  String?  @db.VarChar(1000)
  updated_by     String   @db.Uuid
  updater        User     @relation("NotifSettingUpdatedBy", fields: [updated_by], references: [id])
  updated_at     DateTime @updatedAt

  @@map("notification_event_settings")
}

model ChatbotConfig {
  id          String  @id @default(uuid()) @db.Uuid
  provider    String
  model       String
  is_active   Boolean
  config_json Json
  updated_by  String  @db.Uuid
  updater     User    @relation("ChatbotConfigUpdatedBy", fields: [updated_by], references: [id])

  @@map("chatbot_config")
}

model ChatbotConversation {
  id         String   @id @default(uuid()) @db.Uuid
  user_id    String   @db.Uuid
  user       User     @relation(fields: [user_id], references: [id])
  started_at DateTime @default(now())

  messages ChatbotMessage[]

  @@map("chatbot_conversations")
}

model ChatbotMessage {
  id              String              @id @default(uuid()) @db.Uuid
  conversation_id String              @db.Uuid
  conversation    ChatbotConversation @relation(fields: [conversation_id], references: [id])
  role            ChatbotRole
  content         String              @db.Text
  created_at      DateTime            @default(now())

  @@map("chatbot_messages")
}

// ════════════════════════════════════════════════════════════════════════════════
// MODULE 12 — Data Import & Integration (staging → reconcile → commit)
// ════════════════════════════════════════════════════════════════════════════════

model ImportBatch {
  id               String              @id @default(uuid()) @db.Uuid
  source_file_url  String
  source_type      ImportSourceType
  import_type      ImportType
  client_id        String?             @db.Uuid
  client           Client?             @relation(fields: [client_id], references: [id])
  field_mapping_id String?             @db.Uuid
  field_mapping    ImportFieldMapping? @relation(fields: [field_mapping_id], references: [id])
  status           ImportBatchStatus
  total_rows       Int
  matched_rows     Int
  error_rows       Int
  reconcile_total  Decimal?            @db.Decimal(12, 2)
  error_summary    Json?
  run_by           String              @db.Uuid
  runner           User                @relation("ImportBatchRunBy", fields: [run_by], references: [id])
  created_at       DateTime            @default(now())
  committed_at     DateTime?

  import_rows ImportRow[]

  @@map("import_batches")
}

model ImportFieldMapping {
  id           String           @id @default(uuid()) @db.Uuid
  name         String
  client_id    String?          @db.Uuid
  client       Client?          @relation(fields: [client_id], references: [id])
  source_type  ImportSourceType
  mapping_json Json
  created_by   String           @db.Uuid
  creator      User             @relation("ImportMappingCreatedBy", fields: [created_by], references: [id])

  import_batches ImportBatch[]

  @@map("import_field_mappings")
}

model ImportRow {
  id                String      @id @default(uuid()) @db.Uuid
  import_batch_id   String      @db.Uuid
  import_batch      ImportBatch @relation(fields: [import_batch_id], references: [id])
  row_number        Int
  raw_data          Json
  mapped_data       Json?
  match_status      MatchStatus
  matched_entity_id String?     @db.Uuid // polymorphic — no relation
  issue             String?
  resolved_by       String?     @db.Uuid
  resolver          User?       @relation("ImportRowResolvedBy", fields: [resolved_by], references: [id])

  @@map("import_rows")
}
