# ─────────────────────────────────────────────────────────────────────────────
# Redwave backend environment — TEMPLATE (committed). Copy to backend/.env and
# fill in your REAL values. Never commit the real backend/.env (it is gitignored).
# ─────────────────────────────────────────────────────────────────────────────

# PostgreSQL connection string used by Prisma.
#   • Put your REAL Postgres password in place of YOUR_PASSWORD.
#   • Keep the database name `redwave` (create it first:  CREATE DATABASE redwave;).
#   • Adjust user/host/port if your Postgres differs from the local default.
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@localhost:5432/redwave?schema=public"

# Port the NestJS server listens on.
PORT=3000

# ── Auth / JWT ───────────────────────────────────────────────────────────────
# Use STRONG random secrets (e.g. `openssl rand -base64 48`). Access + refresh use
# different secrets so a leaked access token can never be replayed as a refresh token.
JWT_ACCESS_SECRET="CHANGE_ME_access_secret"
JWT_REFRESH_SECRET="CHANGE_ME_refresh_secret"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL="7d"
# Brute-force lockout: after this many failed logins the account locks for LOCKOUT_MINUTES. (defaults 5 / 15)
LOCKOUT_MAX_ATTEMPTS="5"
LOCKOUT_MINUTES="15"
# OPTIONAL rotation grace — set the PREVIOUS secret here while rotating JWT_ACCESS_SECRET so tokens signed
# with the old secret keep verifying until they expire (zero-downtime rotation). Remove once rotation completes.
JWT_ACCESS_SECRET_OLD=""
# JWT_REFRESH_SECRET_OLD is unused (refresh tokens are opaque DB-backed sessions, not JWTs).

# ── Cookies / CSRF (refresh session) ─────────────────────────────────────────
# The refresh token rides in an httpOnly `rw_refresh` cookie; a readable `rw_csrf` cookie backs the
# double-submit CSRF check. In PRODUCTION (NODE_ENV=production) the cookies are Secure and scoped to
# COOKIE_DOMAIN so api. and www. share them (e.g. `.redwavemarketing.ca`). Leave BLANK in dev (host-only).
NODE_ENV="development"
COOKIE_DOMAIN=""
# Credentialed CORS allowlist (comma-separated frontend origins). REQUIRED in production for the cross-site
# cookie to be accepted. Unset in dev → permissive.
CORS_ORIGIN=""

# ── MFA (TOTP) ───────────────────────────────────────────────────────────────
# Issuer label shown in the authenticator app; TTL of the post-password MFA challenge token.
MFA_ISSUER="Redwave ERP"
MFA_CHALLENGE_TTL="5m"

# ── Swagger / API docs ───────────────────────────────────────────────────────
# /docs is auto-enabled in dev. In production it is DISABLED unless ENABLE_SWAGGER=true, and then it is
# gated behind HTTP Basic auth (set BOTH user + password). Never expose the contract publicly.
ENABLE_SWAGGER="false"
SWAGGER_USER=""
SWAGGER_PASSWORD=""

# ── Email (Resend) — invite / password-reset / notification email ────────────
# When RESEND_API_KEY is set, transactional mail (invite, password reset, temp password) and any
# email-enabled notification is delivered via Resend. Leave BLANK to log the intent only (the build/flows
# still work). EMAIL_FROM must be a verified Resend sender on app.redwavemarketing.ca. Add the DKIM/SPF/MX
# DNS records in Namecheap (see docs).
RESEND_API_KEY=""
EMAIL_FROM="Redwave <noreply@app.redwavemarketing.ca>"
# APP_BASE_URL — the frontend origin every user-facing email link is built from (reset/invite/sign-in).
# REQUIRED IN PRODUCTION (= https://app.redwavemarketing.ca). In dev it defaults to http://localhost:5173,
# so leave it blank locally. If unset in production the backend logs a loud startup error and REFUSES to
# send link-bearing emails (fail-safe — it never emails localhost links to real users). The legacy APP_URL
# name is still honored (deprecated — rename it).
APP_BASE_URL="https://app.redwavemarketing.ca"
# Token lifetimes (minutes): a reset link (default 60) and an invite link (default 10080 = 7 days).
PASSWORD_RESET_TTL_MINUTES="60"
INVITE_TOKEN_TTL_MINUTES="10080"

# ── Seed: initial Super Admin ────────────────────────────────────────────────
# Used ONCE by `npm run prisma:seed`. Set a real strong password before seeding;
# if SEED_SUPERADMIN_PASSWORD is empty the seed uses a flagged placeholder and warns.
SEED_SUPERADMIN_EMAIL="superadmin@redwave.local"
SEED_SUPERADMIN_PASSWORD=""

# ── Seed: demo dataset (opt-in) ──────────────────────────────────────────────
# When SEED_DEMO=yes, `npm run prisma:seed` ALSO seeds the rich DEMO transactional data (re-running wipes +
# regenerates it). NEVER set this on Render/production — every deploy runs prisma:seed, so the demo would
# regenerate transactional data. Leave UNSET in prod; the bootstrap catalogue always seeds.
SEED_DEMO=""

# ── Chatbot (Gemini) ─────────────────────────────────────────────────────────
# Google Gemini API key for the chatbot's natural-language intent classifier. Leave BLANK locally — the
# chatbot then falls back to the deterministic stub router. Set on Render; then flip ChatbotConfig.is_active
# = true to turn the real model on. The model name is read from the ChatbotConfig row (not from here).
GEMINI_API_KEY=""
# Per-user rate-limit / cost-cap on the assistant (graceful "try again shortly", never an error).
# CHATBOT_RPM = messages per 60s (default 10); CHATBOT_DAILY_CAP = conversations per UTC day (default 100).
# Align CHATBOT_DAILY_CAP with the GCP budget alert for the Gemini key.
CHATBOT_RPM="10"
CHATBOT_DAILY_CAP="100"

# ── Expenses: Google Maps (server-authoritative KM distance) ─────────────────
# Server-side key for the Directions API. When set, the backend RE-DERIVES the authoritative km route
# distance from each stop's coordinates (the client total_km is ignored). Leave BLANK to fall back to the
# client-supplied total_km (no-geocoder mode). Enable the Directions API on this key in Google Cloud.
GOOGLE_MAPS_API_KEY=""

# ── FX rate source (multi-currency, stored-FX #12) ───────────────────────────
# Foreign amounts (rep expenses, client billing) freeze a currency→CAD rate at capture (approval / issue)
# and roll up to CAD. This chooses where the day's rate comes from:
#   • FX_RATE_SOURCE="bank_of_canada" → the Bank of Canada Valet API (PUBLIC, no key) pre-fills the rate.
#   • unset / "manual" (DEFAULT) → no auto rate; the approver/issuer must supply a manual override, else a
#     foreign approval/issue is REJECTED (422). Never guesses a rate.
# CAD-only deployments can ignore this entirely (CAD → rate 1, no fetch). Env-gated + graceful (like Maps).
FX_RATE_SOURCE=""
# Timeout (ms) for a Valet lookup before falling back to manual. Optional (default 8000).
FX_HTTP_TIMEOUT_MS=""

# ── File storage (Supabase Storage — PRIVATE bucket) ─────────────────────────
# Backs ALL user file uploads (expense receipts, document originals via the unified POST /v1/files
# pipeline, e-sign copies, rep documents). The bucket must be PRIVATE — bytes are only ever served via
# short-TTL signed URLs minted by RBAC/visibility-gated endpoints; paths are SERVER-generated and every
# upload is recorded in stored_files (who/what/when + sha256). Use the SERVICE ROLE key (server-only
# secret — never expose it to the browser). REQUIRED for file endpoints: when unset, POST /v1/files and
# the signed-URL downloads fail with a clear 503 ("file storage not configured") — never a silent stub.
SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY=""
SUPABASE_STORAGE_BUCKET="receipts"

# ── Seed & reset (handover) ──────────────────────────────────────────────────
#   • `npm run prisma:seed`  — bootstrap catalogue + a rich, idempotent DEMO dataset (re-running upserts,
#     never duplicates). Demo logins use the password baked into prisma/seed/demo.ts (DEMO_PASSWORD);
#     rotate via the UI. The Super Admin password is NEVER overwritten on re-seed.
#   • `npm run seed:reset`   — DESTRUCTIVE clean-wipe of ALL transactional data, KEEPING the master
#     catalogue (login, roles, clients, products, reps, commission config, pay periods, chatbot config).
#     Guarded: it aborts unless RESET_CONFIRM=yes is set, e.g.:
#       RESET_CONFIRM=yes npm -w backend run seed:reset
