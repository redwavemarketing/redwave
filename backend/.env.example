# ─────────────────────────────────────────────────────────────────────────────
# Redwave backend environment — TEMPLATE (committed). Copy to backend/.env and
# fill in your REAL values. Never commit the real backend/.env (it is gitignored).
# ─────────────────────────────────────────────────────────────────────────────

# PostgreSQL connection string used by Prisma.
#   • Put your REAL Postgres password in place of YOUR_PASSWORD.
#   • Keep the database name `redwave` (create it first:  CREATE DATABASE redwave;).
#   • Adjust user/host/port if your Postgres differs from the local default.
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@localhost:5432/redwave?schema=public"

# Port the NestJS server listens on.
PORT=3000

# ── Auth / JWT ───────────────────────────────────────────────────────────────
# Use STRONG random secrets (e.g. `openssl rand -base64 48`). Access + refresh use
# different secrets so a leaked access token can never be replayed as a refresh token.
JWT_ACCESS_SECRET="CHANGE_ME_access_secret"
JWT_REFRESH_SECRET="CHANGE_ME_refresh_secret"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL="7d"
# Brute-force lockout: after this many failed logins the account locks for LOCKOUT_MINUTES. (defaults 5 / 15)
LOCKOUT_MAX_ATTEMPTS="5"
LOCKOUT_MINUTES="15"

# ── Email (Resend) — invite / password-reset / notification email ────────────
# When RESEND_API_KEY is set, transactional mail (invite, password reset, temp password) and any
# email-enabled notification is delivered via Resend. Leave BLANK to log the intent only (the build/flows
# still work). EMAIL_FROM must be a verified Resend sender on app.redwavemarketing.ca; APP_URL is the
# frontend base used to build the links. Add the DKIM/SPF/MX DNS records in Namecheap (see docs).
RESEND_API_KEY=""
EMAIL_FROM="Redwave <noreply@app.redwavemarketing.ca>"
APP_URL="https://app.redwavemarketing.ca"
# Token lifetimes (minutes): a reset link (default 60) and an invite link (default 10080 = 7 days).
PASSWORD_RESET_TTL_MINUTES="60"
INVITE_TOKEN_TTL_MINUTES="10080"

# ── Seed: initial Super Admin ────────────────────────────────────────────────
# Used ONCE by `npm run prisma:seed`. Set a real strong password before seeding;
# if SEED_SUPERADMIN_PASSWORD is empty the seed uses a flagged placeholder and warns.
SEED_SUPERADMIN_EMAIL="superadmin@redwave.local"
SEED_SUPERADMIN_PASSWORD=""

# ── Chatbot (Gemini) ─────────────────────────────────────────────────────────
# Google Gemini API key for the chatbot's natural-language intent classifier. Leave BLANK locally — the
# chatbot then falls back to the deterministic stub router. Set on Render; then flip ChatbotConfig.is_active
# = true to turn the real model on. The model name is read from the ChatbotConfig row (not from here).
GEMINI_API_KEY=""

# ── Expenses: Google Maps (server-authoritative KM distance) ─────────────────
# Server-side key for the Directions API. When set, the backend RE-DERIVES the authoritative km route
# distance from each stop's coordinates (the client total_km is ignored). Leave BLANK to fall back to the
# client-supplied total_km (no-geocoder mode). Enable the Directions API on this key in Google Cloud.
GOOGLE_MAPS_API_KEY=""

# ── Expenses: receipt storage (Supabase Storage) ─────────────────────────────
# When all three are set, receipt uploads go to a Supabase Storage bucket and the API returns an
# access-controlled (signed) URL. Leave BLANK to fall back to a selection-only reference (no real upload).
# Use the SERVICE ROLE key (server-only secret — never expose it to the browser).
SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY=""
SUPABASE_STORAGE_BUCKET="receipts"

# ── Seed & reset (handover) ──────────────────────────────────────────────────
#   • `npm run prisma:seed`  — bootstrap catalogue + a rich, idempotent DEMO dataset (re-running upserts,
#     never duplicates). Demo logins use the password baked into prisma/seed/demo.ts (DEMO_PASSWORD);
#     rotate via the UI. The Super Admin password is NEVER overwritten on re-seed.
#   • `npm run seed:reset`   — DESTRUCTIVE clean-wipe of ALL transactional data, KEEPING the master
#     catalogue (login, roles, clients, products, reps, commission config, pay periods, chatbot config).
#     Guarded: it aborts unless RESET_CONFIRM=yes is set, e.g.:
#       RESET_CONFIRM=yes npm -w backend run seed:reset
