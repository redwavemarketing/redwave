{
  "name": "redwave",
  "version": "0.1.0",
  "private": true,
  "description": "Redwave ERP / HRM platform — single-stack TypeScript modular monolith (monorepo root).",
  "workspaces": [
    "backend",
    "frontend",
    "contract"
  ],
  "scripts": {
    "dev:backend": "npm -w backend run start:dev",
    "dev:frontend": "npm -w frontend run dev",
    "build": "npm -w backend run build && npm -w frontend run build",
    "build:backend": "npm -w backend run build",
    "build:frontend": "npm -w frontend run build",
    "lint": "npm -w backend run lint && npm -w frontend run lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "npm -w backend run test",
    "prisma:generate": "npm -w backend run prisma:generate",
    "prisma:migrate": "npm -w backend run prisma:migrate",
    "prisma:studio": "npm -w backend run prisma:studio"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^9.1.0",
    "globals": "^15.14.0",
    "prettier": "^3.4.2",
    "typescript-eslint": "^8.20.0"
  },
  "engines": {
    "node": ">=20"
  }
}
