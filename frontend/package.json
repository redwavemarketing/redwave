{
  "name": "@redwave/frontend",
  "version": "0.1.0",
  "private": true,
  "description": "Redwave ERP/HRM web frontend — React + Vite (TypeScript). Consumes the OpenAPI contract.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "lint:fix": "eslint \"src/**/*.{ts,tsx}\" --fix",
    "test": "vitest run",
    "stylelint": "stylelint \"src/**/*.css\"",
    "gen:api": "openapi-typescript ../contract/openapi.yaml -o src/api/generated/schema.d.ts",
    "gen:icons": "node scripts/gen-icons.mjs",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\""
  },
  "dependencies": {
    "@fontsource/figtree": "^5.2.10",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@hookform/resolvers": "^5.4.0",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.2.15",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@react-google-maps/api": "^2.20.8",
    "@tanstack/react-query": "^5.101.0",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.8",
    "lucide-react": "^1.17.0",
    "openapi-fetch": "^0.17.0",
    "pdfjs-dist": "^4.10.38",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.77.0",
    "react-router-dom": "^7.16.0",
    "recharts": "^3.8.1",
    "signature_pad": "^5.1.3",
    "write-excel-file": "^4.1.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "@types/react": "^19.0.7",
    "@types/react-dom": "^19.0.3",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.18",
    "openapi-typescript": "^7.13.0",
    "stylelint": "^17.12.0",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-declaration-strict-value": "^1.11.1",
    "to-ico": "^1.1.5",
    "typescript": "^5.7.3",
    "vite": "^6.0.7",
    "vite-plugin-svgr": "^4.3.0",
    "vitest": "^3.0.0"
  }
}
