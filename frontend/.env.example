# Frontend environment variables (Vite). Copy to `.env.local` for local overrides — only `.env.example`
# is committed; all real `.env*` files are gitignored. Vite exposes vars prefixed `VITE_` to the client.

# Backend ORIGIN ONLY for production builds (e.g. Vercel), where there is no Vite dev proxy.
# NO `/v1` and NO trailing slash — the generated API path keys already include `/v1`, and the client
# joins this base with them (see src/api/client.ts). Leave UNSET in development so the Vite dev proxy
# forwards `/v1` to the backend at localhost:3000.
# Example: VITE_API_BASE_URL=https://api.redwave.example
VITE_API_BASE_URL=
